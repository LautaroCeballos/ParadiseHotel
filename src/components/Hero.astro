---

---

<section
    class="relative w-full h-screen min-h-[650px] flex items-center justify-center pt-20"
>
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img
            src="/ParadiseHotel/images/hero.png"
            alt="Luxury Resort Vista"
            class="w-full h-full object-cover object-center"
        />
        <!-- Gradient Overlay -->
        <div
            class="absolute inset-0 bg-gradient-to-b from-brand-dark/60 via-brand-dark/30 to-brand-dark/70"
        >
        </div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-4 flex flex-col items-center">
        <span
            class="font-sans text-brand-light/90 tracking-[0.2em] text-sm md:text-base uppercase mb-4 block font-medium shadow-sm"
            >Refugio Exclusivo</span
        >
        <h1
            class="font-heading text-5xl md:text-7xl lg:text-8xl text-white font-bold mb-6 tracking-tight drop-shadow-lg"
        >
            Tu Escape <br /> al <span
                class="text-brand-light italic font-medium">Paraíso</span
            >
        </h1>
        <p
            class="font-sans text-lg md:text-xl text-brand-light max-w-2xl mb-12 drop-shadow-md"
        >
            Desconecta del mundo en nuestro santuario de lujo. Aguas
            cristalinas, arena blanca y un servicio excepcional te esperan.
        </p>

        <!-- Booking Widget (Interactive Island placeholder) -->
        <div
            class="bg-white/95 backdrop-blur-xl rounded-2xl p-6 shadow-2xl flex flex-col md:flex-row gap-6 items-end max-w-5xl w-full mx-auto transform translate-y-12 absolute -bottom-16 left-0 right-0 border border-white/50"
        >
            <div class="flex-1 w-full flex flex-col text-left">
                <label
                    class="font-sans text-xs uppercase tracking-wider text-slate-500 font-bold mb-2"
                    >Check-in</label
                >
                <input
                    type="date"
                    class="w-full border-b-2 border-slate-200 py-2 focus:outline-none focus:border-brand-accent bg-transparent text-slate-800 font-medium transition-colors cursor-pointer"
                />
            </div>
            <div class="flex-1 w-full flex flex-col text-left">
                <label
                    class="font-sans text-xs uppercase tracking-wider text-slate-500 font-bold mb-2"
                    >Check-out</label
                >
                <input
                    type="date"
                    class="w-full border-b-2 border-slate-200 py-2 focus:outline-none focus:border-brand-accent bg-transparent text-slate-800 font-medium transition-colors cursor-pointer"
                />
            </div>
            <div class="flex-1 w-full flex flex-col text-left">
                <label
                    class="font-sans text-xs uppercase tracking-wider text-slate-500 font-bold mb-2"
                    >Huéspedes</label
                >
                <select
                    class="w-full border-b-2 border-slate-200 py-2 focus:outline-none focus:border-brand-accent bg-transparent text-slate-800 font-medium transition-colors cursor-pointer"
                >
                    <option>2 Adultos</option>
                    <option>1 Adulto</option>
                    <option>Familia (4)</option>
                </select>
            </div>
            <button
                class="w-full md:w-auto bg-brand-accent text-white font-sans font-semibold px-10 py-3.5 rounded-xl hover:bg-brand-dark transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
                Buscar
            </button>
        </div>
    </div>
</section>
