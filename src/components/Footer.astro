---

---

<footer
    id="contacto"
    class="bg-brand-dark text-white pt-24 pb-12 relative overflow-hidden mt-16"
>
    <!-- Top wave shape -->
    <div class="absolute top-0 w-full overflow-hidden leading-none">
        <svg
            class="relative block w-full h-[60px]"
            data-name="Layer 1"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 1200 120"
            preserveAspectRatio="none"
        >
            <path
                d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z"
                class="fill-white"></path>
        </svg>
    </div>

    <div
        class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 mt-8"
    >
        <div class="md:col-span-1">
            <a href="#" class="flex items-center gap-2 group mb-6">
                <div
                    class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-brand-dark font-heading font-bold text-xl"
                >
                    R
                </div>
                <span
                    class="font-heading font-bold text-2xl text-white tracking-wide"
                    >Paradise<span class="text-brand-accent">.</span></span
                >
            </a>
            <p class="font-sans text-brand-light/70 text-sm mb-6 max-w-sm">
                Creando memorias imborrables. El destino de lujo definitivo
                rodeado de la naturaleza en su máxima expresión.
            </p>
        </div>

        <div>
            <h4 class="font-heading font-bold text-xl mb-6">Explorar</h4>
            <ul class="space-y-4">
                <li>
                    <a
                        href="#habitaciones"
                        class="font-sans text-brand-light/80 hover:text-brand-accent transition-colors text-sm"
                        >Habitaciones</a>
                </li>
                <li>
                    <a
                        href="#experiencias"
                        class="font-sans text-brand-light/80 hover:text-brand-accent transition-colors text-sm"
                        >Experiencias</a>
                </li>
                <li>
                    <a
                        href="#testimonios"
                        class="font-sans text-brand-light/80 hover:text-brand-accent transition-colors text-sm"
                        >Testimonios</a>
                </li>
            </ul>
        </div>

        <div>
            <h4 class="font-heading font-bold text-xl mb-6">Políticas</h4>
            <ul class="space-y-4">
                <li>
                    <a
                        href="#"
                        class="font-sans text-brand-light/80 hover:text-brand-accent transition-colors text-sm"
                        >Términos y Condiciones</a>
                </li>
                <li>
                    <a
                        href="#"
                        class="font-sans text-brand-light/80 hover:text-brand-accent transition-colors text-sm"
                        >Privacidad</a>
                </li>
            </ul>
        </div>

        <div>
            <h4 class="font-heading font-bold text-xl mb-6">Contacto</h4>
            <ul class="space-y-4">
                <li
                    class="font-sans text-brand-light/80 text-sm flex items-center gap-3"
                >
                    123 Paradise Blvd, Playa Dorada
                </li>
                <li
                    class="font-sans text-brand-light/80 text-sm flex items-center gap-3"
                >
                    info@paradiseresort.com
                </li>
                <li
                    class="font-sans text-brand-light/80 text-sm flex items-center gap-3"
                >
                    +1 234 567 8900
                </li>
            </ul>
        </div>
    </div>

    <div
        class="max-w-7xl mx-auto px-6 border-t border-brand-light/10 mt-16 pt-8 text-center md:text-left flex flex-col md:flex-row justify-between items-center gap-4"
    >
        <p class="font-sans text-brand-light/50 text-sm">
            © 2026 Paradise Resort. Todos los derechos reservados.
        </p>
    </div>
</footer>
