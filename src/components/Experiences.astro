---
const experiences = [
    {
        title: "Bienestar y Spa",
        desc: "Revitaliza tu cuerpo y mente con tratamientos ancestrales combinados con técnicas modernas en nuestro santuario de paz.",
        image: "/images/spa.png",
    },
    {
        title: "Gastronomía Gourmet",
        desc: "Un viaje culinario donde los sabores locales se encuentran con la alta cocina internacional.",
        image: "/images/hero.png",
    },
    {
        title: "Aventuras Acuáticas",
        desc: "Explora el arrecife de coral, practica snorkel o disfruta de un atardecer a bordo de nuestros veleros.",
        image: "/images/room.png",
    },
];
---

<section id="experiencias" class="py-24 bg-sand relative overflow-hidden">
    <!-- Forma curva decorativa superior inspirada en la plantilla original -->
    <div
        class="absolute -top-1 left-0 w-full h-24 bg-white"
        style="border-bottom-right-radius: 50% 100%; border-bottom-left-radius: 50% 100%;"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10 pt-16">
        <div class="text-center mb-16 max-w-2xl mx-auto">
            <span
                class="font-sans text-brand-accent uppercase tracking-widest text-sm font-bold block mb-3"
                >Estilo de Vida</span
            >
            <h2
                class="font-heading text-4xl md:text-5xl text-brand-dark font-bold mb-6"
            >
                Experiencias Inolvidables
            </h2>
            <p class="font-sans text-slate-600 text-lg">
                Creamos momentos mágicos que recordarás para siempre. Descubre
                todo lo que nuestro resort tiene preparado para ti.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                experiences.map((exp) => (
                    <div class="group relative rounded-3xl overflow-hidden cursor-pointer shadow-lg">
                        <div class="h-[400px] w-full">
                            <img
                                src={exp.image}
                                alt={exp.title}
                                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700"
                            />
                        </div>
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/95 via-brand-dark/40 to-transparent flex flex-col justify-end p-8">
                            <h3 class="font-heading text-2xl text-white font-bold mb-2 group-hover:-translate-y-2 transition-transform duration-300">
                                {exp.title}
                            </h3>
                            <p class="font-sans text-white/90 text-sm opacity-0 group-hover:opacity-100 group-hover:-translate-y-2 transition-all duration-300 delay-75">
                                {exp.desc}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>

    <!-- Forma curva decorativa inferior -->
    <div
        class="absolute -bottom-1 left-0 w-full h-24 bg-white"
        style="border-top-right-radius: 50% 100%; border-top-left-radius: 50% 100%;"
    >
    </div>
</section>
